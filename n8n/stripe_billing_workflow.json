            "parameters": {
                "jsCode": "// Map Stripe plan ID to subscription tier\nconst planMapping = {\n  'price_pro_monthly': 'Pro',\n  'price_pro_yearly': 'Pro',\n  'price_enterprise_monthly': 'Enterprise',\n  'price_enterprise_yearly': 'Enterprise'\n};\n\nconst stripeData = $('Verify Stripe Signature').item.json;\nconst merchantData = $json.results[0];\n\n// Calculate expiry date (+30 days for monthly, +365 for yearly)\nconst currentPeriodEnd = new Date(stripeData.current_period_end * 1000);\n\nreturn {\n  json: {\n    merchant_id: merchantData.id,\n    merchant_row_id: merchantData.id,\n    subscription_plan: planMapping[stripeData.plan_id] || 'Pro',\n    subscription_status: 'Active',\n    stripe_subscription_id: stripeData.subscription_id,\n    expiry_date: currentPeriodEnd.toISOString(),\n    stripe_customer_id: stripeData.customer_id\n  }\n};"
            },
