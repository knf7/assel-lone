                "jsCode": "// Extend expiry date by 30 days\nconst merchantData = $json.results[0];\nconst currentExpiry = new Date(merchantData.expiry_date);\nconst newExpiry = new Date(currentExpiry.getTime() + (30 * 24 * 60 * 60 * 1000));\n\nreturn {\n  json: {\n    merchant_row_id: merchantData.id,\n    new_expiry_date: newExpiry.toISOString(),\n    merchant_name: merchantData.business_name,\n    whatsapp_phone: merchantData.whatsapp_phone_id\n  }\n};"
            },
