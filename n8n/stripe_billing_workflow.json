        {
            "parameters": {
                "jsCode": "// Verify Stripe signature (IMPORTANT for security)\nconst crypto = require('crypto');\n\nconst payload = $input.item.binary.data.toString();\nconst signature = $input.item.headers['stripe-signature'];\nconst webhookSecret = $env.STRIPE_WEBHOOK_SECRET;\n\n// Parse signature header\nconst elements = signature.split(',');\nconst signatureData = {};\nelements.forEach(element => {\n  const [key, value] = element.split('=');\n  signatureData[key] = value;\n});\n\nconst timestamp = signatureData.t;\nconst expectedSignature = signatureData.v1;\n\n// Create signed payload\nconst signedPayload = `${timestamp}.${payload}`;\nconst computedSignature = crypto\n  .createHmac('sha256', webhookSecret)\n  .update(signedPayload)\n  .digest('hex');\n\n// Verify signature\nif (computedSignature !== expectedSignature) {\n  throw new Error('Invalid Stripe signature');\n}\n\n// Parse event data\nconst event = JSON.parse(payload);\n\nreturn {\n  json: {\n    event_type: event.type,\n    event_id: event.id,\n    customer_id: event.data.object.customer,\n    subscription_id: event.data.object.id,\n    status: event.data.object.status,\n    current_period_end: event.data.object.current_period_end,\n    plan_id: event.data.object.items?.data[0]?.price?.id,\n    amount: event.data.object.items?.data[0]?.price?.unit_amount / 100,\n    raw_event: event\n  }\n};"
            },
            "id": "verify-stripe-signature",
            "name": "Verify Stripe Signature",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                450,
                300
            ]
        },
        {
