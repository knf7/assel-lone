                                },
                                "conditions": [
                                    {
                                        "leftValue": "={{$json.event_type}}",
                                        "rightValue": "invoice.payment_succeeded",
                                        "operator": {
                                            "type": "string",
                                            "operation": "equals"
                                        }
                                    }
                                ]
                            },
                            "renameOutput": true,
