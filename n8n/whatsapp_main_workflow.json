    {
      "parameters": {
        "jsCode": "// Merge customer data\nconst aiData = $('Parse AI Response').item.json;\nconst checkResult = $('Check Customer Exists').item.json;\n\nlet customerId;\nif (checkResult.results && checkResult.results.length > 0) {\n  customerId = checkResult.results[0].id;\n} else {\n  customerId = $json.id;\n}\n\nreturn {\n  json: {\n    ...aiData,\n    customer_id: customerId\n  }\n};"
      },
