{
  "name": "WhatsApp Loan Management - Main Workflow",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "whatsapp-webhook",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "WhatsApp Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "whatsapp-loan-webhook"
    },
    {
      "parameters": {
        "jsCode": "// Extract phone number and message from WhatsApp webhook\nconst body = $input.item.json.body;\n\nconst fromPhone = body?.entry?.[0]?.changes?.[0]?.value?.messages?.[0]?.from;\nconst messageText = body?.entry?.[0]?.changes?.[0]?.value?.messages?.[0]?.text?.body;\nconst messageType = body?.entry?.[0]?.changes?.[0]?.value?.messages?.[0]?.type;\nconst mediaUrl = body?.entry?.[0]?.changes?.[0]?.value?.messages?.[0]?.image?.id;\n\nreturn {\n  json: {\n    from_phone: fromPhone,\n    message_text: messageText,\n    message_type: messageType,\n    media_url: mediaUrl,\n    raw_webhook: body\n  }\n};"
      },
      "id": "extract-phone",
      "name": "Extract Phone & Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 300]
    },
    {
      "parameters": {
        "url": "={{$env.BASEROW_BASE_URL}}/api/database/rows/table/{{$env.MERCHANTS_TABLE_ID}}/",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "filter__whatsapp_phone_id__equal",
              "value": "={{$json.from_phone}}"
            }
          ]
        },
        "options": {}
      },
      "id": "lookup-merchant",
      "name": "Lookup Merchant",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [650, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "baserow-auth",
          "name": "Baserow API Token"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false
          },
          "conditions": [
            {
              "leftValue": "={{$json.results.length}}",
              "rightValue": "0",
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            },
            {
              "leftValue": "={{$json.results[0].subscription_status}}",
              "rightValue": "Active",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "auth-check",
