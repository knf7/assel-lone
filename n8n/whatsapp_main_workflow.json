    {
      "parameters": {
        "jsCode": "// Calculate total outstanding debt\nconst loans = $json.results || [];\nconst totalOutstanding = loans.reduce((sum, loan) => sum + parseFloat(loan.amount), 0);\nconst totalLoans = loans.length;\n\nreturn {\n  json: {\n    total_outstanding: totalOutstanding.toFixed(2),\n    total_loans: totalLoans,\n    merchant_name: $('Parse AI Response').item.json.merchant_name,\n    from_phone: $('Parse AI Response').item.json.from_phone\n  }\n};"
      },
