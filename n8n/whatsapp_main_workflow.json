    {
      "parameters": {
        "url": "https://api.whatsapp.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "messaging_product",
              "value": "whatsapp"
            },
            {
              "name": "to",
              "value": "={{$('Extract Phone & Message').item.json.from_phone}}"
            },
            {
              "name": "type",
              "value": "text"
            },
            {
              "name": "text",
              "value": "={\"body\": \"⛔ غير مصرح لك باستخدام هذا النظام. للاشتراك، تواصل مع الدعم.\"}"
            }
          ]
        },
        "options": {}
      },
      "id": "unauthorized-reply",
      "name": "Send Unauthorized Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1050, 450],
      "credentials": {
        "httpHeaderAuth": {
          "id": "whatsapp-api-auth",
          "name": "WhatsApp API Token"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Store merchant data for use in subsequent nodes\nconst merchant = $json.results[0];\n\nreturn {\n  json: {\n    merchant_id: merchant.id,\n    merchant_name: merchant.business_name,\n    merchant_email: merchant.email,\n    subscription_plan: merchant.subscription_plan,\n    message_text: $('Extract Phone & Message').item.json.message_text,\n    message_type: $('Extract Phone & Message').item.json.message_type,\n    media_url: $('Extract Phone & Message').item.json.media_url,\n    from_phone: $('Extract Phone & Message').item.json.from_phone\n  }\n};"
      },
      "id": "set-merchant-context",
      "name": "Set Merchant Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1050, 150]
    },
    {
      "parameters": {
        "model": "llama-3-70b-8192",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "أنت مساعد ذكي لاستخراج البيانات من رسائل WhatsApp العربية. مهمتك:\n\n1. تحديد النية (Intent):\n   - NEW_LOAN: تسجيل دين جديد\n   - REPORT: طلب تقرير الديون\n   - SEARCH: البحث عن عميل\n   - EXPORT: تصدير البيانات\n   - CHAT: محادثة عامة\n\n2. استخراج البيانات:\n   - الاسم الكامل (full_name)\n   - المبلغ (amount) - رقم فقط\n   - رقم الهوية (national_id)\n   - رقم الجوال (mobile_number)\n   - رقم الإيصال (receipt_number)\n\nأرجع JSON فقط بهذا الشكل:\n{\n  \"intent\": \"NEW_LOAN\",\n  \"full_name\": \"أحمد علي\",\n  \"amount\": 5000,\n  \"national_id\": \"1234567890\",\n  \"mobile_number\": \"+966500000000\",\n  \"receipt_number\": \"REC-001\"\n}\n\nإذا لم تجد معلومة، ضع null."
            },
            {
              "role": "user",
              "content": "={{$json.message_text}}"
            }
          ]
        },
        "options": {
          "temperature": 0.1,
          "maxTokens": 500
        }
      },
      "id": "groq-ai-extraction",
      "name": "Groq AI Extraction",
      "type": "n8n-nodes-base.groq",
      "typeVersion": 1,
      "position": [1250, 150],
      "credentials": {
        "groqApi": {
          "id": "groq-api-cred",
          "name": "Groq API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse AI response and merge with merchant context\nconst aiResponse = JSON.parse($json.message.content);\nconst merchantContext = $('Set Merchant Context').item.json;\n\nreturn {\n  json: {\n    ...merchantContext,\n    ...aiResponse,\n    timestamp: new Date().toISOString()\n  }\n};"
      },
      "id": "parse-ai-response",
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1450, 150]
    },
    {
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": false
                },
                "conditions": [
                  {
                    "leftValue": "={{$json.intent}}",
                    "rightValue": "NEW_LOAN",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "NEW_LOAN"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false
                },
                "conditions": [
                  {
                    "leftValue": "={{$json.intent}}",
                    "rightValue": "REPORT",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "REPORT"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false
                },
                "conditions": [
                  {
                    "leftValue": "={{$json.intent}}",
                    "rightValue": "SEARCH",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "SEARCH"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false
                },
                "conditions": [
                  {
                    "leftValue": "={{$json.intent}}",
                    "rightValue": "EXPORT",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "EXPORT"
            }
          ]
        },
        "fallbackOutput": "extra"
      },
      "id": "intent-router",
      "name": "Intent Router",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [1650, 150]
    },
