# =====================================================
# Database Configuration
# =====================================================
POSTGRES_DB=loan_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD_IN_PRODUCTION
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# =====================================================
# Baserow Configuration
# =====================================================
BASEROW_PUBLIC_URL=https://your-domain.com
BASEROW_SECRET_KEY=GENERATE_RANDOM_SECRET_KEY_HERE

# After Baserow setup, get these IDs from the UI
MERCHANTS_TABLE_ID=
CUSTOMERS_TABLE_ID=
LOANS_TABLE_ID=

# =====================================================
# n8n Configuration
# =====================================================
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_THIS_N8N_PASSWORD
N8N_HOST=your-domain.com
N8N_PROTOCOL=https
N8N_WEBHOOK_URL=https://your-domain.com

# =====================================================
# External API Keys
# =====================================================
# Groq AI API Key (Get from: https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# WhatsApp Business API (Get from: https://business.facebook.com)
WHATSAPP_API_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Stripe API Keys (Get from: https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Google Drive API (Optional - for receipt storage)
GOOGLE_DRIVE_CLIENT_ID=your_client_id
GOOGLE_DRIVE_CLIENT_SECRET=your_client_secret
GOOGLE_DRIVE_REFRESH_TOKEN=your_refresh_token
GOOGLE_DRIVE_FOLDER_ID=your_folder_id

# =====================================================
# Frontend Configuration
# =====================================================
REACT_APP_API_URL=https://your-domain.com/api
REACT_APP_BASEROW_URL=https://your-domain.com/baserow

# =====================================================
# General Configuration
# =====================================================
TIMEZONE=Asia/Riyadh
NODE_ENV=production

# =====================================================
# SSL/TLS Configuration (for production)
# =====================================================
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# =====================================================
# Backup Configuration
# =====================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# =====================================================
# Monitoring & Logging
# =====================================================
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn_for_error_tracking
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1

# =====================================================
# Rate Limiting
# =====================================================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# =====================================================
# Email Configuration (for notifications)
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@your-domain.com

# =====================================================
# Clerk Authentication (Backend)
# =====================================================
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY
CLERK_WEBHOOK_SECRET=whsec_YOUR_CLERK_WEBHOOK_SECRET

# =====================================================
# Grafana Monitoring
# =====================================================
GRAFANA_PASSWORD=admin123
