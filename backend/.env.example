NODE_ENV=production

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=loan_management
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# JWT
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=24h

# Admin security
ADMIN_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_ADMIN_SECRET_MIN_32_CHARS
ADMIN_PASSWORD=CHANGE_THIS_TO_A_STRONG_ADMIN_PASSWORD

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Monitoring / alerts
SENTRY_DSN=
ALERT_WINDOW_MS=60000
ALERT_MIN_REQUESTS=20
ALERT_5XX_RATE_PERCENT=5
ALERT_P95_MS=1200
ALERT_COOLDOWN_MS=300000
MONITOR_MAX_5XX_RATE=5
MONITOR_MAX_P95_MS=1200

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_pro_plan_id
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_plan_id
